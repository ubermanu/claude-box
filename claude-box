#!/usr/bin/env bash
set -euo pipefail

# claude-box — one command: boot an isolated Docker box + attach interactive Claude.
#
#   claude-box <owner/repo>            # create a box from a GitHub repo, then attach
#   claude-box <owner/repo> -p "..."   # create a box, boot Claude with an initial prompt
#   cat PROMPT.md | claude-box <owner/repo>   # same, prompt piped on stdin
#   claude-box <id>                    # reattach to a running box
#
# Pure Docker. The box environment is ~/.claude-box/Dockerfile (yours to edit).
# The repo's default branch is cloned into a Docker VOLUME — never on the host fs.
#
# Each box gets a random 5-char id; volume + container are keyed by it.
# Multiple boxes run concurrently.
#
# Isolation:
#   - repo code lives in a Docker VOLUME (claude-box-<id>), never on host fs
#   - claude sessions persist on the host at ~/.claude-box/sessions/claude-box-<id>, bound to
#     this box only (other boxes' sessions never leak in); reattach resumes them
#   - your Claude subscription creds copied in; nothing else of host auth
#   - GH_TOKEN (clone + push) read from ~/.claude-box/.env, injected via --env-file

# --- colors (only when stdout is a TTY) ----------------------------------------
if [ -t 1 ]; then
  BOLD=$'\033[1m'; DIM=$'\033[2m'; RESET=$'\033[0m'
  CYAN=$'\033[36m'; GREEN=$'\033[32m'; YELLOW=$'\033[33m'; RED=$'\033[31m'; MAGENTA=$'\033[35m'
else
  BOLD=''; DIM=''; RESET=''; CYAN=''; GREEN=''; YELLOW=''; RED=''; MAGENTA=''
fi

step() { printf '%s  →%s  %s\n'        "$CYAN$BOLD"    "$RESET" "$*"; }
ok()   { printf '%s  ✓%s  %s\n'        "$GREEN$BOLD"   "$RESET" "$*"; }
dim()  { printf '     %s%s%s\n'         "$DIM"          "$*"    "$RESET"; }
warn() { printf '%s  ⚠%s  %s\n'        "$YELLOW$BOLD"  "$RESET" "$*" >&2; }
die()  { printf '%s  ✗%s  %s\n'        "$RED$BOLD"     "$RESET" "$*" >&2; exit 1; }

box_header() {
  local id="$1" hint="$2"
  printf '\n%s  ┌─ claude-box ─────────────────────────┐%s\n' "$MAGENTA$BOLD" "$RESET"
  printf '%s  │%s  box id   %s%-28s%s%s  │%s\n' "$MAGENTA$BOLD" "$RESET" "$BOLD" "$id" "$RESET" "$MAGENTA$BOLD" "$RESET"
  printf '%s  │%s  reattach %s%-28s%s%s  │%s\n' "$MAGENTA$BOLD" "$RESET" "$DIM"  "$hint" "$RESET" "$MAGENTA$BOLD" "$RESET"
  printf '%s  └───────────────────────────────────────┘%s\n\n' "$MAGENTA$BOLD" "$RESET"
}

# random 5-char id (lowercase alnum); subshell disables pipefail so head's
# early close doesn't trip the `tr` SIGPIPE under `set -o pipefail`.
genid() { ( set +o pipefail; LC_ALL=C tr -dc 'a-z0-9' </dev/urandom | head -c5 ); }

# parse args: a single positional (owner/repo | id), plus an optional -p/--prompt.
PROMPT=""; POS=()
while [ $# -gt 0 ]; do
  case "$1" in
    -p|--prompt) PROMPT="${2:?-p needs a prompt}"; shift 2 ;;
    -p*)         PROMPT="${1#-p}"; shift ;;
    --prompt=*)  PROMPT="${1#--prompt=}"; shift ;;
    *)           POS+=("$1"); shift ;;
  esac
done
# no -p but stdin is piped (not a tty) -> read the prompt from stdin
[ -z "$PROMPT" ] && [ ! -t 0 ] && PROMPT="$(cat)"

ARG="${POS[0]:?usage: claude-box <owner/repo> [-p PROMPT] (create) | claude-box <id> (reattach)}"
case "$ARG" in
  */*) REPO="$ARG"; ID="$(genid)" ;;   # owner/repo -> create a new box
  *)   REPO="";     ID="$ARG"     ;;   # bare id    -> reattach
esac

BOX_HOME="${CLAUDE_BOX_HOME:-$HOME/.claude-box}"
DOCKERFILE="$BOX_HOME/Dockerfile"
ENVFILE="$BOX_HOME/.env"                 # global env, KEY=value per line, chmod 600
HOMEADD="$BOX_HOME/homeadditions"        # dotfiles/config copied into the box home
IMG="claude-box"                         # built from ~/.claude-box/Dockerfile
VOL="claude-box-$ID"                     # repo code lives here
NIXVOL="claude-box-nix"                  # shared /nix store across all boxes (seeded from image)
SESS="$BOX_HOME/sessions/claude-box-$ID" # host dir holding THIS box's claude sessions
CRED="$HOME/.claude/.credentials.json"
SOCK="/home/user/.claude-box.sock"       # dtach session socket (inside container)
# command the dtach session runs (resolved at attach time inside the container).
# If this box already has a recorded session, resume it (claude --continue);
# else if an initial prompt was seeded (-p / stdin), boot Claude with it;
# otherwise start fresh. The session dir is bind-mounted from the host (see below).
# If the repo ships a direnv .envrc (e.g. `use flake`), trust it and launch Claude
# inside that loaded env (direnv exec) so the project's Nix dev shell is autoloaded.
RUN='cd /workspaces/repo && CLAUDE="$(command -v claude || echo "$HOME/.local/bin/claude")"; PF="$HOME/.claude-box-prompt"; SYS="$HOME/.claude-box-system-prompt"; DE=""; if [ -f .envrc ]; then direnv allow . >/dev/null 2>&1 || true; DE="direnv exec ."; fi; run_claude() { if [ -s "$SYS" ]; then exec $DE "$CLAUDE" --dangerously-skip-permissions --append-system-prompt "$(cat "$SYS")" "$@"; else exec $DE "$CLAUDE" --dangerously-skip-permissions "$@"; fi; }; if ls "$HOME"/.claude/projects/*/*.jsonl >/dev/null 2>&1; then run_claude --continue; elif [ -s "$PF" ]; then run_claude "$(cat "$PF")"; else run_claude; fi'

cid() { docker ps -q --filter "label=claude-box=$ID" | head -1; }
# -A: attach if the session is live, else create it (self-heals after claude exits)
# -E -z: no dtach keybinds (Ctrl-\ detach and Ctrl-Z suspend both pass through)
# If the prompt was piped in, our stdin is the pipe, not a terminal; reconnect
# /dev/tty so the attached Claude session stays interactive.
attach() {
  if [ ! -t 0 ] && [ -e /dev/tty ]; then
    exec docker exec -it -u user "$1" dtach -A "$SOCK" -E -z bash -lc "$RUN" < /dev/tty
  fi
  exec docker exec -it -u user "$1" dtach -A "$SOCK" -E -z bash -lc "$RUN"
}

# --- already running -> attach -------------------------------------------------
EXIST="$(cid)"
if [ -n "$EXIST" ]; then
  step "box ${BOLD}$ID${RESET} is running, attaching"
  attach "$EXIST"
fi

# --- create path --------------------------------------------------------------
[ -n "$REPO" ] || die "box '$ID' does not exist — pass <owner/repo> to create one"
[ -f "$CRED" ] || die "no Claude credentials at $CRED — run 'claude' once on host first"
box_header "$ID" "claude-box $ID"

# --- seed ~/.claude-box defaults on first run ---------------------------------
mkdir -p "$BOX_HOME" "$HOMEADD"
[ -f "$ENVFILE" ] || { touch "$ENVFILE"; chmod 600 "$ENVFILE"; }
[ -f "$BOX_HOME/.dockerignore" ] || printf '*\n!Dockerfile\n' > "$BOX_HOME/.dockerignore"
if [ ! -f "$DOCKERFILE" ]; then
  cat > "$DOCKERFILE" <<'DOCKERFILE'
# claude-box environment — edit freely.
# Must keep a uid-1000 'user' account with passwordless sudo, plus git + gh.
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
      sudo git curl ca-certificates gnupg dtach jq moreutils xz-utils direnv \
 && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
 && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
 && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list \
 && apt-get update && apt-get install -y --no-install-recommends gh \
 && rm -rf /var/lib/apt/lists/*

# uid-1000 'user' account with passwordless sudo, plus /nix owned by it so the
# single-user Nix installer needs no root.
RUN useradd -m -u 1000 -s /bin/bash user \
 && echo 'user ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/user && chmod 0440 /etc/sudoers.d/user \
 && install -d -m 0755 -o user -g user /nix

USER user
# Docker sets neither HOME nor USER for a USER directive; nix.sh gates its PATH
# export on both being set, so define them here.
ENV HOME=/home/user USER=user
WORKDIR /workspaces

# Nix (single-user, owned by user) with flakes, plus nix-direnv wired into direnv so a
# project's .envrc (`use flake`) autoloads at launch. /nix is a shared docker volume at
# runtime; an empty volume auto-seeds from this image layer on first use.
RUN curl -fsSL https://nixos.org/nix/install | sh -s -- --no-daemon --no-channel-add \
 && mkdir -p "$HOME/.config/nix" "$HOME/.config/direnv" \
 && printf 'experimental-features = nix-command flakes\n' > "$HOME/.config/nix/nix.conf" \
 && . "$HOME/.nix-profile/etc/profile.d/nix.sh" \
 && nix profile install nixpkgs#nix-direnv \
 && printf 'source $HOME/.nix-profile/share/nix-direnv/direnvrc\n' > "$HOME/.config/direnv/direnvrc"

# claude installs to ~/.local/bin; nix profile bins on PATH too. Keep both so the native
# installer doesn't warn and `command -v claude` / direnv / nix all resolve.
ENV PATH=/home/user/.nix-profile/bin:/home/user/.local/bin:$PATH
DOCKERFILE
  ok "seeded $DOCKERFILE"
fi

# --- build the box image (layer cache makes this ~free when unchanged) --------
step "building image ${BOLD}$IMG${RESET}"
docker build -t "$IMG" "$BOX_HOME"

# --- populate volume: clone the repo's default branch (never on host fs) -------
GT="$(grep '^GH_TOKEN=' "$ENVFILE" 2>/dev/null | head -1 | cut -d= -f2- || true)"
CLONE_URL="https://github.com/$REPO.git"
step "cloning ${BOLD}$CLONE_URL${RESET}"
dim "volume: $VOL"
docker volume create "$VOL" >/dev/null
docker run --rm -v "$VOL":/ws alpine sh -c 'rm -rf /ws/repo'
# GH_TOKEN is handed to git via a credential helper through the env, so it never
# lands on argv, in ps, or in the repo's .git/config.
ENV_ARGS=(); GIT_OPTS=()
[ -n "$GT" ] && { ENV_ARGS=(-e GH_TOKEN); GIT_OPTS=(-c 'credential.helper=!f(){ echo username=x-access-token; echo "password=$GH_TOKEN"; }; f'); }
GH_TOKEN="$GT" docker run --rm ${ENV_ARGS[@]+"${ENV_ARGS[@]}"} -v "$VOL":/ws alpine/git \
  ${GIT_OPTS[@]+"${GIT_OPTS[@]}"} clone --quiet "$CLONE_URL" /ws/repo
# work on a dedicated branch off the default branch, not the default branch itself
docker run --rm -v "$VOL":/ws alpine/git -C /ws/repo checkout -q -b "claude-box-$ID"
docker run --rm -v "$VOL":/ws alpine chown -R 1000:1000 /ws

# --- run the box --------------------------------------------------------------
# claude sessions persist on the host at $SESS, bind-mounted onto just this box's
# ~/.claude/projects — so other boxes' sessions never appear in this container.
mkdir -p "$SESS"
# shared nix store: an empty named volume auto-seeds from the image's /nix on first
# use, so the dev-shell closure is downloaded once and reused by every later box.
docker volume create "$NIXVOL" >/dev/null
step "starting container"
BOX="$(docker run -d --label "claude-box=$ID" \
  --mount "source=$VOL,target=/workspaces,type=volume" \
  --mount "source=$NIXVOL,target=/nix,type=volume" \
  --mount "type=bind,source=$SESS,target=/home/user/.claude/projects" \
  --env-file "$ENVFILE" \
  "$IMG" sleep infinity)"

# the projects bind-mount makes Docker pre-create ~/.claude owned by root; hand
# the dir back to user so claude can write settings.json + creds into it.
docker exec -u root "$BOX" chown user:user /home/user/.claude

# --- homeadditions -> box home, then Claude creds -----------------------------
if [ -n "$(ls -A "$HOMEADD" 2>/dev/null)" ]; then
  docker cp "$HOMEADD/." "$BOX":/home/user/
  docker exec -u root "$BOX" chown -R user:user /home/user
fi
docker exec -u user "$BOX" mkdir -p /home/user/.claude
docker cp "$CRED" "$BOX":/home/user/.claude/.credentials.json
docker exec -u root "$BOX" chown user:user /home/user/.claude/.credentials.json
docker exec -u root "$BOX" chmod 600 /home/user/.claude/.credentials.json

# --- in-container setup -------------------------------------------------------
SETUP="$(mktemp)"
cat > "$SETUP" <<'SETUP'
#!/usr/bin/env bash
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive
command -v dtach >/dev/null 2>&1 || { sudo apt-get update -qq && sudo apt-get install -y -qq dtach >/dev/null; }
if ! command -v claude >/dev/null 2>&1 && [ ! -x "$HOME/.local/bin/claude" ]; then
  curl -fsSL https://claude.ai/install.sh | bash
fi
# pre-accept onboarding + the workspace trust dialog (per-project) in ~/.claude.json
f="$HOME/.claude.json"; t="$(mktemp)"
{ [ -s "$f" ] && cat "$f" || echo '{}'; } | jq '.hasCompletedOnboarding=true | .bypassPermissionsModeAccepted=true | .projects["/workspaces/repo"].hasTrustDialogAccepted=true' > "$t" && mv "$t" "$f"
# pre-accept the interactive --dangerously-skip-permissions disclaimer in ~/.claude/settings.json
mkdir -p "$HOME/.claude"; f="$HOME/.claude/settings.json"; t="$(mktemp)"
{ [ -s "$f" ] && cat "$f" || echo '{}'; } | jq '.skipDangerousModePermissionPrompt=true' > "$t" && mv "$t" "$f"
if [ -n "${GH_TOKEN:-}" ]; then
  echo "$GH_TOKEN" | gh auth login --with-token 2>/dev/null || true
  gh auth setup-git 2>/dev/null || true
fi
rm -f "$HOME/.claude-box.sock"   # stale socket from a prior container, if any
SETUP
docker cp "$SETUP" "$BOX":/tmp/claude-box-setup.sh
rm -f "$SETUP"
step "installing claude & dtach"
docker exec -u user "$BOX" bash /tmp/claude-box-setup.sh

# --- inject sandbox system prompt (read by $RUN on every boot) ----------------
printf 'You are running inside claude-box — an isolated Docker sandbox.\nBox: claude-box-%s  |  Branch: claude-box-%s\n\nAfter making changes to the codebase, commit them with a clear git commit message and push the branch:\n  git add -A && git commit -m "..." && git push origin claude-box-%s\nThis ensures your work is preserved and can be reviewed as a pull request once the session ends.\n' \
  "$ID" "$ID" "$ID" \
  | docker exec -i -u user "$BOX" sh -c 'cat > "$HOME/.claude-box-system-prompt"'

# --- seed the initial prompt (read by $RUN on first boot) ---------------------
if [ -n "$PROMPT" ]; then
  step "seeding initial prompt"
  printf '%s' "$PROMPT" | docker exec -i -u user "$BOX" sh -c 'cat > "$HOME/.claude-box-prompt"'
fi

step "attaching to box ${BOLD}$ID${RESET}"
attach "$BOX"
